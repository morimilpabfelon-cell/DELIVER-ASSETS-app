{
  "expo": {
    "name": "DELIVER ASSETS Business",
    "slug": "deliver-assets-business",
    "version": "2.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deliverassetsbusiness",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deliverassets.business",
      "buildNumber": "23"
    },
    "android": {
      "package": "com.deliverassets.business",
      "adaptiveIcon": {
        "backgroundColor": "#FFD400",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "versionCode": 23
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFD400"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DELIVER ASSETS Business usa tus fotos para elegir el logo, la imagen del local y las fotografías reales de los productos.",
          "cameraPermission": "DELIVER ASSETS Business usa la cámara para fotografiar el local y los productos del catálogo.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
