{
  "name": "deliver-assets-business",
  "main": "expo-router/entry",
  "version": "2.3.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "android:device": "expo run:android --device --port 8082",
    "start:device": "expo start --dev-client --localhost --clear --port 8082",
    "qa": "npm run typecheck && npm run lint && npm run qa:split && npm run qa:business && npm run qa:media && npm run qa:inventory && npm run qa:product-media && npm run qa:feedback && npm run qa:size",
    "doctor": "expo-doctor",
    "qa:split": "node scripts/split-audit.mjs",
    "qa:business": "node scripts/business-audit.mjs",
    "qa:media": "node scripts/business-media-audit.mjs",
    "qa:feedback": "node scripts/feedback-audit.mjs",
    "qa:size": "node scripts/size-audit.mjs",
    "android:release": "expo run:android --variant release --port 8082",
    "qa:inventory": "node scripts/inventory-audit.mjs",
    "qa:product-media": "node scripts/product-media-audit.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "expo-image-picker": "~17.0.11",
    "expo-file-system": "~19.0.23"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
