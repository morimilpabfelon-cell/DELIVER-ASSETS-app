{
  "expo": {
    "name": "DELIVER ASSETS Rider",
    "slug": "deliver-assets-rider",
    "version": "2.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deliverassetsrider",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deliverassets.rider",
      "buildNumber": "23"
    },
    "android": {
      "package": "com.deliverassets.rider",
      "adaptiveIcon": {
        "backgroundColor": "#1347FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "versionCode": 23
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#1347FF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DELIVER ASSETS usa tus fotos para adjuntar evidencias al chat del pedido.",
          "cameraPermission": "DELIVER ASSETS usa la cámara para registrar evidencias del pedido.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
